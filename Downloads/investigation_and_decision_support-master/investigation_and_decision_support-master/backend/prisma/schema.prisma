datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// NOTE: SQLite does not support native enums.
// All enum fields are stored as String. Values are validated in application code.
// TypeScript enums are declared in src/utils/enums.ts for compile-time safety.

model User {
  id              String         @id @default(uuid())
  email           String         @unique
  passwordHash    String
  name            String
  badgeNumber     String         @unique
  role            String         // Role enum: POLICE_OFFICER | INVESTIGATION_OFFICER | POLICE_INSPECTOR | CRIME_ANALYST | SCRB_ADMINISTRATOR | SYSTEM_ADMINISTRATOR
  districtId      String?
  district        District?      @relation(fields: [districtId], references: [id])
  policeStationId String?
  policeStation   PoliceStation? @relation(fields: [policeStationId], references: [id])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  auditLogs       AuditLog[]
  notifications   Notification[]
  workspaces      InvestigationWorkspace[]

  @@index([role])
  @@index([districtId])
}

model District {
  id        String          @id @default(uuid())
  name      String          @unique
  code      String          @unique
  state     String          @default("Karnataka")
  latitude  Float?
  longitude Float?
  stations  PoliceStation[]
  users     User[]
  FIRs      FIR[]
}

model PoliceStation {
  id         String   @id @default(uuid())
  name       String
  code       String   @unique
  districtId String
  district   District @relation(fields: [districtId], references: [id])
  users      User[]
  FIRs       FIR[]

  @@index([districtId])
}

model CrimeCategory {
  id          String @id @default(uuid())
  name        String @unique
  code        String @unique
  description String?
  FIRs        FIR[]
}

model FIR {
  id                 String                   @id @default(uuid())
  firNumber          String                   @unique
  policeStationId    String
  policeStation      PoliceStation            @relation(fields: [policeStationId], references: [id])
  districtId         String
  district           District                 @relation(fields: [districtId], references: [id])
  crimeCategoryId    String
  crimeCategory      CrimeCategory            @relation(fields: [crimeCategoryId], references: [id])
  status             String                   @default("PENDING") // FIRStatus
  dateOfOffence      DateTime
  dateOfRegistration DateTime                 @default(now())
  summary            String
  latitude           Float?
  longitude          Float?
  address            String
  complainantName    String?
  complainantPhone   String?
  suspects           CriminalFIRAssociation[]
  evidence           Evidence[]
  vehicles           Vehicle[]
  phones             Phone[]
  timeline           CaseActivity[]
  pinnedWorkspaces   PinnedCase[]

  @@index([status])
  @@index([districtId])
  @@index([policeStationId])
  @@index([crimeCategoryId])
  @@index([dateOfOffence])
  @@index([dateOfRegistration])
}

model CaseActivity {
  id              String   @id @default(uuid())
  firId           String
  fir             FIR      @relation(fields: [firId], references: [id], onDelete: Cascade)
  action          String
  description     String
  performedBy     String
  performedByName String
  timestamp       DateTime @default(now())

  @@index([firId])
}

model Criminal {
  id            String                   @id @default(uuid())
  name          String
  aliases       String?
  photoUrl      String?
  aadhaarNumber String?                  @unique
  dateOfBirth   DateTime?
  gender        String?
  riskScore     Int                      @default(0)
  status        String                   @default("ACTIVE") // CriminalStatus
  associations  CriminalFIRAssociation[]
  vehicles      Vehicle[]
  phones        Phone[]
  associates    AssociateRelation[]      @relation("CriminalAssociates")
  associateOf   AssociateRelation[]      @relation("CriminalAssociateOf")
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  @@index([riskScore])
  @@index([status])
}

model CriminalFIRAssociation {
  id           String   @id @default(uuid())
  criminalId   String
  criminal     Criminal @relation(fields: [criminalId], references: [id], onDelete: Cascade)
  firId        String
  fir          FIR      @relation(fields: [firId], references: [id], onDelete: Cascade)
  role         String   @default("SUSPECT") // SuspectRole
  arrestDate   DateTime?
  arrestStatus String?  @default("WANTED")

  @@unique([criminalId, firId])
  @@index([firId])
  @@index([criminalId])
}

model Evidence {
  id              String   @id @default(uuid())
  firId           String
  fir             FIR      @relation(fields: [firId], references: [id], onDelete: Cascade)
  type            String   // EvidenceType
  description     String
  storageLocation String
  collectedBy     String
  collectedAt     DateTime @default(now())
  serialNumber    String?

  @@index([firId])
}

model Vehicle {
  id                 String     @id @default(uuid())
  make               String
  model              String
  registrationNumber String     @unique
  color              String
  ownerName          String?
  ownerPhone         String?
  criminals          Criminal[]
  cases              FIR[]
}

model Phone {
  id          String     @id @default(uuid())
  phoneNumber String     @unique
  imei        String?    @unique
  carrier     String?
  ownerName   String?
  criminals   Criminal[]
  cases       FIR[]
}

model AssociateRelation {
  id           String   @id @default(uuid())
  criminalId   String
  criminal     Criminal @relation("CriminalAssociates", fields: [criminalId], references: [id], onDelete: Cascade)
  associateId  String
  associate    Criminal @relation("CriminalAssociateOf", fields: [associateId], references: [id], onDelete: Cascade)
  relationType String   // RelationType
  notes        String?

  @@unique([criminalId, associateId])
  @@index([criminalId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  content   String
  type      String   // NotificationType
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  badge     String?
  action    String
  details   String
  ipAddress String?
  timestamp DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([timestamp])
}

model InvestigationWorkspace {
  id          String       @id @default(uuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes       String       @default("")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  pinnedCases PinnedCase[]

  @@index([userId])
}

model PinnedCase {
  id          String                 @id @default(uuid())
  workspaceId String
  workspace   InvestigationWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  firId       String
  fir         FIR                    @relation(fields: [firId], references: [id], onDelete: Cascade)
  pinnedAt    DateTime               @default(now())
}
